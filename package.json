{
  "name": "@feelrobotics/feel-apps-api",
  "version": "1.0.4",
  "description": "Feel Apps JavaScript API",
  "author": "feelrobotics",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "lint": "biome lint ./src",
    "format": "biome format ./src --write",
    "check": "biome check ./src",
    "check:fix": "biome check ./src --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/jest": "^29.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "socket.io-client": "^4.7.5"
  }
}
