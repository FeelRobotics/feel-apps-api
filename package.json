{
  "name": "@feelrobotics/feel-apps-api",
  "version": "2.1.0",
  "description": "Real-time haptic feedback and device control library for Feel Robotics applications",
  "author": "Feel Robotics <info@feelrobotics.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/feelrobotics/feel-apps-api.git"
  },
  "bugs": {
    "url": "https://github.com/feelrobotics/feel-apps-api/issues"
  },
  "homepage": "https://github.com/feelrobotics/feel-apps-api#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "lint": "biome lint ./src",
    "format": "biome format ./src --write",
    "typecheck": "tsc --noEmit",
    "check": "biome check ./src",
    "check:fix": "biome check ./src --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/jest": "^29.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "socket.io-client": "^4.7.5"
  }
}
